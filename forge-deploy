#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER_DEPLOY_SCRIPT="${SCRIPT_DIR}/server-deploy"
REPO_ROOT="${SCRIPT_DIR}"
REPO_NAME="$(basename "$REPO_ROOT")"
REPO_PARENT="$(dirname "$REPO_ROOT")"

REMOTE_USER="root"
REMOTE_HOST="49.13.65.81"
REMOTE_PORT="22"
SSH_KEY=""

TAR_PATH="/home/bedrock-forge.tar.xz"
APP_DIR="/home/bedrock-forge"

RUN_SEED="false"
LOG_FILE=""
TMP_DIR=""
TMP_ARCHIVE=""

if [[ ! -x "$SERVER_DEPLOY_SCRIPT" ]]; then
  echo "✗ Missing executable: ${SERVER_DEPLOY_SCRIPT}" >&2
  exit 1
fi

cleanup() {
  if [[ -n "$TMP_DIR" && -d "$TMP_DIR" ]]; then
    rm -rf "$TMP_DIR"
  fi
}

trap cleanup EXIT

print_usage() {
  cat <<'EOF'
Usage:
  ./forge-deploy <update|reset> [options]

Commands:
  update                  Update stack and preserve data by default
  reset                   Full reset (wipes volumes and re-seeds)

Options:
  --seed                  Seed after update (reset always seeds)
  --tar <path>            Tar archive path (default: /home/bedrock-forge.tar.xz)
  --app-dir <path>        App directory (default: /home/bedrock-forge)
  --host <host>           SSH host (default: 49.13.65.81)
  --user <user>           SSH user (default: root)
  --port <port>           SSH port (default: 22)
  --ssh-key <path>        SSH private key path
  --log-file <path>       Local deploy log path (default: logs/deploy/<timestamp>-<mode>.log)
  -h, --help              Show this help

Examples:
  ./forge-deploy update
  ./forge-deploy update --seed
  ./forge-deploy reset
  ./forge-deploy reset --host 49.13.65.81 --user root
EOF
}

if [[ $# -eq 0 ]]; then
  print_usage
  exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
  -h|--help|help)
    print_usage
    exit 0
    ;;
  update|reset)
    ;;
  *)
    echo "✗ Unknown command: ${COMMAND}" >&2
    print_usage
    exit 1
    ;;
esac

while [[ $# -gt 0 ]]; do
  case "$1" in
    --seed)
      RUN_SEED="true"
      shift
      ;;
    --tar)
      TAR_PATH="${2:-}"
      shift 2
      ;;
    --app-dir)
      APP_DIR="${2:-}"
      shift 2
      ;;
    --host)
      REMOTE_HOST="${2:-}"
      shift 2
      ;;
    --user)
      REMOTE_USER="${2:-}"
      shift 2
      ;;
    --port)
      REMOTE_PORT="${2:-}"
      shift 2
      ;;
    --ssh-key)
      SSH_KEY="${2:-}"
      shift 2
      ;;
    --log-file)
      LOG_FILE="${2:-}"
      shift 2
      ;;
    -h|--help)
      print_usage
      exit 0
      ;;
    *)
      echo "✗ Unknown option: $1" >&2
      print_usage
      exit 1
      ;;
  esac
done

if [[ -z "$REMOTE_HOST" ]]; then
  echo "✗ --host cannot be empty" >&2
  exit 1
fi

if [[ -n "$SSH_KEY" && ! -f "$SSH_KEY" ]]; then
  echo "✗ SSH key not found: ${SSH_KEY}" >&2
  exit 1
fi

for required_bin in tar ssh scp; do
  if ! command -v "$required_bin" >/dev/null 2>&1; then
    echo "✗ Missing required command: ${required_bin}" >&2
    exit 1
  fi
done

TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
if [[ -z "$LOG_FILE" ]]; then
  LOG_FILE="${REPO_ROOT}/logs/deploy/${TIMESTAMP}-${COMMAND}.log"
elif [[ "$LOG_FILE" != /* ]]; then
  LOG_FILE="${REPO_ROOT}/${LOG_FILE}"
fi

mkdir -p "$(dirname "$LOG_FILE")"
exec > >(tee -a "$LOG_FILE") 2>&1

SSH_OPTS=(-p "$REMOTE_PORT")
SCP_OPTS=(-P "$REMOTE_PORT")

if [[ -n "$SSH_KEY" ]]; then
  SSH_OPTS+=(-i "$SSH_KEY")
  SCP_OPTS+=(-i "$SSH_KEY")
fi

REMOTE_TARGET="${REMOTE_USER}@${REMOTE_HOST}"
TMP_DIR="$(mktemp -d)"
ARCHIVE_ROOT="$(basename "$APP_DIR")"
TMP_ARCHIVE="${TMP_DIR}/${ARCHIVE_ROOT}.tar.xz"

echo "Starting ${COMMAND} deploy to ${REMOTE_TARGET}"
echo "Local repo: ${REPO_ROOT}"
echo "Remote tar path: ${TAR_PATH}"
echo "Remote app dir: ${APP_DIR}"
echo "Log file: ${LOG_FILE}"

echo "Creating archive"
tar -cJf "$TMP_ARCHIVE" \
  --exclude="${REPO_NAME}/.git" \
  --exclude="${REPO_NAME}/.github" \
  --exclude="${REPO_NAME}/logs" \
  --exclude='*/__pycache__' \
  --exclude='*.pyc' \
  --exclude='*/.pytest_cache' \
  --exclude='*/.mypy_cache' \
  --exclude='*/.ruff_cache' \
  --exclude='*/.venv' \
  --exclude='*/venv' \
  --exclude="${REPO_NAME}/dashboard/node_modules" \
  --exclude="${REPO_NAME}/dashboard/dist" \
  --exclude="${REPO_NAME}/dashboard/.vite" \
  --transform "s|^${REPO_NAME}|${ARCHIVE_ROOT}|" \
  -C "$REPO_PARENT" "$REPO_NAME"

FIRST_ENTRY="$(tar -tf "$TMP_ARCHIVE" | head -n 1 || true)"
if [[ "$FIRST_ENTRY" != "${ARCHIVE_ROOT}/" && "$FIRST_ENTRY" != "${ARCHIVE_ROOT}" && "$FIRST_ENTRY" != ${ARCHIVE_ROOT}/* ]]; then
  echo "✗ Invalid archive layout. Expected top-level folder '${ARCHIVE_ROOT}/', got '${FIRST_ENTRY:-<empty>}'" >&2
  exit 1
fi

echo "Archive created: ${TMP_ARCHIVE} ($(du -h "$TMP_ARCHIVE" | awk '{print $1}'))"

REMOTE_TAR_DIR="$(dirname "$TAR_PATH")"
echo "Ensuring remote tar directory exists: ${REMOTE_TAR_DIR}"
ssh "${SSH_OPTS[@]}" "$REMOTE_TARGET" "mkdir -p $(printf '%q' "$REMOTE_TAR_DIR")"

echo "Uploading archive"
scp "${SCP_OPTS[@]}" "$TMP_ARCHIVE" "${REMOTE_TARGET}:${TAR_PATH}"

REMOTE_ARGS=(--mode "$COMMAND" --tar "$TAR_PATH" --app-dir "$APP_DIR")

if [[ "$COMMAND" == "update" && "$RUN_SEED" == "true" ]]; then
  REMOTE_ARGS+=(--seed)
fi

REMOTE_CMD="bash -s --"
for arg in "${REMOTE_ARGS[@]}"; do
  REMOTE_CMD+=" $(printf '%q' "$arg")"
done

echo "Running remote deployment"
ssh "${SSH_OPTS[@]}" "$REMOTE_TARGET" "$REMOTE_CMD" < "$SERVER_DEPLOY_SCRIPT"

echo "✓ forge-deploy ${COMMAND} completed"
echo "Log saved to ${LOG_FILE}"
