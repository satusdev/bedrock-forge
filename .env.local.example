# Bedrock Forge - Local Docker Environment
# Copy to .env for local development/testing:
# cp .env.local.example .env

COMPOSE_PROJECT_NAME=forge-local

POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forge

SECRET_KEY=dev-secret-key-not-for-production
ENCRYPTION_KEY=dev-encryption-key
DEBUG=true

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/api/v1/ws

SEED_DEMO_MODE=true

# Optional seeding values for non-demo mode
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FULL_NAME=Administrator

# Optional integrations (leave blank for local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/settings?oauth=google
GOOGLE_DRIVE_CREDENTIALS_FILE=
GOOGLE_DRIVE_TOKEN_FILE=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
CLOUDFLARE_API_TOKEN=
# Optional absolute path to rclone.conf file (must be a file path, not a directory)
RCLONE_CONFIG=
