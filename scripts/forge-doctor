#!/usr/bin/env bash
set -euo pipefail

echo "🩺 Bedrock Forge Doctor (Docker/Nest)"

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

check_cmd() {
  if command -v "$1" >/dev/null 2>&1; then
    echo "✅ $1 found"
  else
    echo "❌ $1 missing"
    return 1
  fi
}

status=0
check_cmd docker || status=1
check_cmd curl || status=1

if ! docker info >/dev/null 2>&1; then
  echo "❌ Docker daemon not reachable"
  status=1
else
  echo "✅ Docker daemon reachable"
fi

if [[ -f docker-compose.yml ]]; then
  echo "✅ docker-compose.yml found"
else
  echo "❌ docker-compose.yml missing"
  status=1
fi

if [[ -f .env ]]; then
  echo "✅ .env found"
else
  echo "⚠️ .env missing (copy from .env.local.example)"
fi

echo
if docker compose ps >/dev/null 2>&1; then
  docker compose ps
fi

echo
if curl -fsS http://localhost:8000/api/v1/health >/dev/null 2>&1; then
  echo "✅ API health endpoint reachable"
else
  echo "⚠️ API health endpoint not reachable"
fi

exit $status
