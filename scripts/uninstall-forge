#!/usr/bin/env bash
set -euo pipefail

echo "🗑️ Bedrock Forge local teardown"

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

if ! command -v docker >/dev/null 2>&1; then
  echo "✗ docker is required" >&2
  exit 1
fi

read -r -p "Stop containers and remove local volumes for this workspace? (y/N): " reply
if [[ ! "$reply" =~ ^[Yy]$ ]]; then
  echo "Cancelled."
  exit 0
fi

docker compose down -v --remove-orphans

echo "✅ Local containers and volumes removed"
