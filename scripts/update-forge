#!/usr/bin/env bash
set -euo pipefail

echo "🔄 Updating Bedrock Forge workspace"

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

if ! command -v git >/dev/null 2>&1; then
  echo "✗ git is required" >&2
  exit 1
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "✗ docker is required" >&2
  exit 1
fi

git pull --ff-only

if [[ ! -f .env && -f .env.local.example ]]; then
  cp .env.local.example .env
  echo "✓ Created .env from .env.local.example"
fi

echo "Running non-destructive update (schema sync + api/dashboard rebuild)"
./scripts/compose-safe.sh update

echo "✅ Update complete"
