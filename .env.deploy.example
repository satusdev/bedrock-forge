# ─── Bedrock Forge — Deployment Configuration ────────────────────────────────
# Copy to .env.deploy and fill in your values.
# This file is NOT committed to git (.env.deploy is gitignored).
#
# Usage: ./deploy.sh

# SSH user on the target server (usually root or a deploy user)
SERVER_USER=root

# Server IP or hostname
SERVER_HOST=your.server.ip.or.hostname

# Absolute path on the server where the project will live
SERVER_PATH=/home/forge

# Public domain (used for CORS_ORIGIN and deployment output)
# Include the scheme: https://forge.example.com
DOMAIN=https://forge.example.com
