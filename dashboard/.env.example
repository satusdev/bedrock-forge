# API Configuration
# If you are using docker compose build args, set these in the compose env file instead.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# WebSocket Configuration (optional override)
# If not set, this is derived from VITE_API_BASE_URL
# VITE_WS_URL=ws://localhost:8000/api/v1/ws

# Development settings
VITE_DEV_MODE=true
VITE_LOG_LEVEL=debug

# Optional: GitHub OAuth (if needed)
# VITE_GITHUB_CLIENT_ID=your_github_client_id

# Optional: Google Drive OAuth (if needed)
# VITE_GOOGLE_CLIENT_ID=your_google_client_id