{
	"name": "forge-api",
	"version": "0.1.0",
	"private": true,
	"description": "NestJS + Prisma API for Bedrock Forge migration",
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"start": "node dist/main",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"lint": "eslint \"{src,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"prisma:generate": "sh -c 'DATABASE_URL=${DATABASE_URL:-postgresql://forge:forge@localhost:5432/forge} prisma generate'",
		"prisma:pull": "sh -c 'DATABASE_URL=${DATABASE_URL:-postgresql://forge:forge@localhost:5432/forge} prisma db pull'",
		"prisma:baseline": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/0000_baseline.sql",
		"prisma:push": "sh -c 'DATABASE_URL=${DATABASE_URL:-postgresql://forge:forge@localhost:5432/forge} prisma db push'",
		"prisma:migrate": "sh -c 'DATABASE_URL=${DATABASE_URL:-postgresql://forge:forge@localhost:5432/forge} prisma migrate dev'",
		"prisma:deploy": "sh -c 'DATABASE_URL=${DATABASE_URL:-postgresql://forge:forge@localhost:5432/forge} prisma migrate deploy'",
		"prisma:seed": "sh -c 'DATABASE_URL=${DATABASE_URL:-postgresql://forge:forge@localhost:5432/forge} prisma generate && node prisma/seed.cjs'"
	},
	"prisma": {
		"seed": "node prisma/seed.cjs"
	},
	"dependencies": {
		"@fastify/formbody": "^8.0.2",
		"@nestjs/common": "^10.4.15",
		"@nestjs/config": "^3.2.3",
		"@nestjs/core": "^10.4.15",
		"@nestjs/platform-express": "^10.4.15",
		"@nestjs/schedule": "^6.1.1",
		"@prisma/client": "^6.19.2",
		"bcryptjs": "^2.4.3",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"jsonwebtoken": "^9.0.2",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"ws": "^8.19.0"
	},
	"devDependencies": {
		"@nestjs/cli": "^10.4.9",
		"@nestjs/schematics": "^10.2.3",
		"@nestjs/testing": "^10.4.15",
		"@types/bcryptjs": "^2.4.6",
		"@types/express": "^5.0.0",
		"@types/jest": "^29.5.14",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^22.13.10",
		"@types/supertest": "^6.0.2",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"eslint": "^9.21.0",
		"eslint-config-prettier": "^10.0.2",
		"jest": "^29.7.0",
		"prettier": "^3.5.2",
		"prisma": "^6.19.2",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.6",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.57.0"
	}
}
