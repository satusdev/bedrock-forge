{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "CommonJS",
		"moduleResolution": "Node",
		"ignoreDeprecations": "5.0",
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": "./",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"composite": false,
		"declaration": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "test"]
}
