{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "CommonJS",
		"moduleResolution": "Node",
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": "./",
		"paths": {
			"@bedrock-forge/shared": ["../../packages/shared/src/index.ts"],
			"@bedrock-forge/remote-executor": [
				"../../packages/remote-executor/src/index.ts"
			]
		},
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"declaration": false,
		"noUnusedLocals": false,
		"noUnusedParameters": false
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "test"]
}
