# ── Build caches ─────────────────────────────────────────────────────────────
.turbo/
**/*.tsbuildinfo

# ── Compiled outputs (builder stage recompiles these) ────────────────────────
# NOTE: packages/*/dist/ is intentionally NOT excluded; packages like
# @bedrock-forge/shared must have their pre-built .d.ts available for
# downstream compilation if using a local cache. Builder stage rebuilds anyway.
apps/*/dist/

# ── Node modules (installed fresh inside Docker) ─────────────────────────────
node_modules/
apps/*/node_modules/
packages/*/node_modules/

# ── Tests, coverage, docs ────────────────────────────────────────────────────
**/__tests__/
**/*.test.ts
**/*.spec.ts
**/coverage/
docs/
tasks/

# ── Development & tooling ────────────────────────────────────────────────────
.agents/
.github/
.vscode/
.idea/

# ── Shell scripts (not needed inside image) ───────────────────────────────────
deploy.sh
dev.sh
install.sh
reset.sh
update.sh

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── OS / editor artefacts ─────────────────────────────────────────────────────
*.DS_Store
*.swp
*.swo

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Local env overrides ───────────────────────────────────────────────────────
# .env is passed at runtime via docker compose env_file, not baked into image.
.env
.env.*
!.env.example
