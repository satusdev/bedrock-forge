generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured via prisma.config.ts (Prisma 7)
}

// ──────────────────────────────────────────────────────────────────────────────
// IDENTITY & ACCESS
// ──────────────────────────────────────────────────────────────────────────────

model User {
  id            BigInt    @id @default(autoincrement())
  email         String    @unique
  name          String
  password_hash         String
  mfa_enabled           Boolean   @default(false)
  totp_secret_encrypted String?
  created_at            DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @updatedAt @db.Timestamptz()

  user_roles          UserRole[]
  refresh_tokens      RefreshToken[]
  audit_logs          AuditLog[]
  notifications       UserNotification[]
  finding_acks        SecurityFindingAck[]
  resource_notes      ResourceNote[]
  maintenance_windows MaintenanceWindow[]

  @@map("users")
}

model Role {
  id   BigInt @id @default(autoincrement())
  name String @unique // admin | manager | client

  user_roles UserRole[]

  @@map("roles")
}

model UserRole {
  user_id BigInt
  role_id BigInt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@index([user_id])
  @@index([role_id])
  @@map("user_roles")
}

model RefreshToken {
  id          BigInt    @id @default(autoincrement())
  user_id     BigInt
  token_hash  String    @unique
  expires_at  DateTime  @db.Timestamptz()
  revoked_at  DateTime? @db.Timestamptz()
  created_at  DateTime  @default(now()) @db.Timestamptz()
  user_agent  String?   @db.Text
  ip_address  String?   @db.VarChar(45)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@index([revoked_at])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────────────────────────────────────────────
// CLIENT MANAGEMENT
// ──────────────────────────────────────────────────────────────────────────────

model Client {
  id         BigInt    @id @default(autoincrement())
  name       String
  email      String?
  phone      String?
  notes      String?
  created_at DateTime  @default(now()) @db.Timestamptz()
  updated_at DateTime  @updatedAt @db.Timestamptz()

  client_tags ClientTag[]
  projects    Project[]
  invoices    Invoice[]

  @@map("clients")
}

model Tag {
  id    BigInt @id @default(autoincrement())
  name  String @unique
  color String @default("#6366f1")

  client_tags      ClientTag[]
  environment_tags EnvironmentTag[]

  @@map("tags")
}

model ClientTag {
  client_id BigInt
  tag_id    BigInt

  client Client @relation(fields: [client_id], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([client_id, tag_id])
  @@index([client_id])
  @@index([tag_id])
  @@map("client_tags")
}

model EnvironmentTag {
  environment_id BigInt
  tag_id         BigInt

  environment Environment @relation(fields: [environment_id], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([environment_id, tag_id])
  @@index([environment_id])
  @@index([tag_id])
  @@map("environment_tags")
}

// ──────────────────────────────────────────────────────────────────────────────
// PACKAGES
// ──────────────────────────────────────────────────────────────────────────────

model HostingPackage {
  id            BigInt   @id @default(autoincrement())
  name          String
  description   String?
  price_monthly Decimal  @db.Decimal(10, 2)
  storage_gb    Int
  bandwidth_gb  Int
  max_sites     Int
  active        Boolean  @default(true)

  projects Project[]
  invoices Invoice[]

  @@map("hosting_packages")
}

model SupportPackage {
  id              BigInt   @id @default(autoincrement())
  name            String
  description     String?
  price_monthly   Decimal  @db.Decimal(10, 2)
  response_hours  Int
  includes_updates Boolean @default(false)
  active          Boolean  @default(true)

  projects Project[]
  invoices Invoice[]

  @@map("support_packages")
}

// ──────────────────────────────────────────────────────────────────────────────
// INFRASTRUCTURE
// ──────────────────────────────────────────────────────────────────────────────

model Server {
  id                      BigInt   @id @default(autoincrement())
  name                    String
  ip_address              String
  ssh_port                Int      @default(22)
  ssh_user                String   @default("root")
  ssh_private_key_encrypted String // AES-256-GCM encrypted
  provider                String?  // e.g. "hetzner", "digitalocean", "vultr"
  cost_monthly            Decimal? @db.Decimal(10, 2) // Monthly server cost for margin tracking
  status                  ServerStatus @default(unknown)
  cyberpanel_login        Json?    // Encrypted JSON: { url, username, password }
  cyberpanel_version      String?  // Detected from /usr/local/CyberCP/version.txt via SSH
  created_at              DateTime @default(now()) @db.Timestamptz()
  updated_at              DateTime @updatedAt @db.Timestamptz()

  environments             Environment[]
  job_executions           JobExecution[]
  security_scans           SecurityScan[]
  security_scan_schedules  SecurityScanSchedule[]
  security_alert_setting   ServerSecurityAlertSetting?
  finding_acks             SecurityFindingAck[]
  maintenance_windows      MaintenanceWindow[]

  @@map("servers")
}

enum ServerStatus {
  online
  offline
  unknown
}

model Project {
  id                 BigInt   @id @default(autoincrement())
  name               String
  client_id          BigInt
  hosting_package_id BigInt?
  support_package_id BigInt?
  status             ProjectStatus @default(active)
  created_at         DateTime @default(now()) @db.Timestamptz()
  updated_at         DateTime @updatedAt @db.Timestamptz()

  client          Client          @relation(fields: [client_id], references: [id], onDelete: Restrict)
  hosting_package HostingPackage? @relation(fields: [hosting_package_id], references: [id])
  support_package SupportPackage? @relation(fields: [support_package_id], references: [id])
  environments    Environment[]
  invoices        Invoice[]

  @@index([client_id])
  @@index([hosting_package_id])
  @@index([support_package_id])
  @@map("projects")
}

enum ProjectStatus {
  active
  inactive
  archived
}

model Environment {
  id                BigInt   @id @default(autoincrement())
  project_id        BigInt
  server_id         BigInt
  type              String   @default("production") // Free-text: production, staging, development, etc.
  url               String
  root_path         String
  backup_path       String?  // Persistent remote path for backup storage (e.g. /home/user/backups)
  google_drive_folder_id String? // Optional Google Drive folder ID for backup storage override
  protected_tables  String[] @default([]) // WP table names excluded from DB push/clone (data preserved on target)
  sql_protection_queries String[] @default([]) // SQL queries run on target after DB push/clone to protect/sanitize/filter data
  protected_post_types   String[] @default([]) // WP custom post types preserved on target during DB push/clone
  is_baseline       Boolean  @default(false) // marked as the canonical reference env for drift detection
  is_multisite      Boolean  @default(false) // WordPress Multisite installation
  multisite_url     String?  // Primary site URL used for WP-CLI --url flag on multisite
  created_at        DateTime @default(now()) @db.Timestamptz()
  updated_at        DateTime @updatedAt @db.Timestamptz()

  project            Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  server             Server            @relation(fields: [server_id], references: [id])
  backups                Backup[]
  plugin_scans           PluginScan[]
  theme_scans            ThemeScan[]
  monitors               Monitor[]
  wp_db_credentials      WpDbCredentials?
  job_executions         JobExecution[]
  backup_schedule        BackupSchedule?
  plugin_update_schedule PluginUpdateSchedule?
  cleanup_schedule       CleanupSchedule?
  environment_tags          EnvironmentTag[]
  custom_plugins            EnvironmentCustomPlugin[]
  security_scans            SecurityScan[]
  security_scan_schedules   SecurityScanSchedule?
  finding_acks              SecurityFindingAck[]
  lighthouse_audits         LighthouseAudit[]
  maintenance_windows       MaintenanceWindow[]

  @@index([project_id])
  @@index([server_id])
  @@unique([server_id, root_path])
  @@map("environments")
}

// EnvironmentType enum removed — type is now a free-text String field on Environment

// ──────────────────────────────────────────────────────────────────────────────
// OPERATIONS
// ──────────────────────────────────────────────────────────────────────────────

model Backup {
  id               BigInt       @id @default(autoincrement())
  environment_id   BigInt
  job_execution_id BigInt?
  type             BackupType
  status           BackupStatus @default(pending)
  file_path        String?
  size_bytes       BigInt?
  error_message    String?
  started_at       DateTime?    @db.Timestamptz()
  completed_at     DateTime?    @db.Timestamptz()
  created_at       DateTime     @default(now()) @db.Timestamptz()

  environment   Environment  @relation(fields: [environment_id], references: [id], onDelete: Cascade)
  jobExecution  JobExecution? @relation(fields: [job_execution_id], references: [id], onDelete: SetNull)

  @@index([environment_id])
  @@index([job_execution_id])
  @@index([status])
  @@map("backups")
}

model BackupSchedule {
  id             BigInt     @id @default(autoincrement())
  environment_id BigInt     @unique
  type           BackupType @default(full)
  frequency      String     // 'daily' | 'weekly' | 'monthly'
  hour           Int        @default(3)
  minute         Int        @default(0)
  day_of_week    Int?       // 0=Sun..6=Sat (weekly only)
  day_of_month   Int?       // 1-28 (monthly only)
  enabled        Boolean    @default(true)
  last_run_at    DateTime?  @db.Timestamptz()
  retention_count Int?       // Keep last N completed scheduled backups — null = unlimited
  retention_days  Int?       // Delete scheduled backups older than N days — null = never
  created_at     DateTime   @default(now()) @db.Timestamptz()
  updated_at     DateTime   @updatedAt @db.Timestamptz()

  environment Environment @relation(fields: [environment_id], references: [id], onDelete: Cascade)

  @@index([enabled])
  @@map("backup_schedules")
}

enum BackupType {
  full
  db_only
  files_only
  incremental
}

enum BackupStatus {
  pending
  running
  completed
  failed
}

model PluginScan {
  id             BigInt   @id @default(autoincrement())
  environment_id BigInt
  plugins        Json     // Object { is_bedrock: boolean, plugins: Plugin[] } or legacy array of Plugin objects
  scanned_at     DateTime @default(now()) @db.Timestamptz()
  created_at     DateTime @default(now()) @db.Timestamptz()

  environment Environment @relation(fields: [environment_id], references: [id], onDelete: Cascade)

  @@index([environment_id])
  @@index([scanned_at])
  @@map("plugin_scans")
}

model ThemeScan {
  id             BigInt   @id @default(autoincrement())
  environment_id BigInt
  themes         Json     // ThemeInfo[] — output of `wp theme list --format=json`
  scanned_at     DateTime @default(now()) @db.Timestamptz()
  created_at     DateTime @default(now()) @db.Timestamptz()

  environment Environment @relation(fields: [environment_id], references: [id], onDelete: Cascade)

  @@index([environment_id])
  @@index([scanned_at])
  @@map("theme_scans")
}

model Domain {
  id              BigInt    @id @default(autoincrement())
  name            String    @unique
  whois_json      Json?     // Raw WHOIS response parsed as JSON
  expires_at      DateTime? @db.Timestamptz()
  last_checked_at DateTime? @db.Timestamptz()
  ssl_json        Json?     // Raw TLS certificate data
  ssl_expires_at  DateTime? @db.Timestamptz()
  ssl_issuer      String?
  ssl_checked_at  DateTime? @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()

  @@index([name])
  @@index([expires_at])
  @@index([ssl_expires_at])
  @@map("domains")
}

model Monitor {
  id               BigInt    @id @default(autoincrement())
  environment_id   BigInt    @unique
  enabled          Boolean   @default(true)
  interval_seconds Int       @default(600)
  uptime_pct       Decimal   @db.Decimal(5, 2) @default(100.00)
  last_response_ms Int?
  last_status      Int?      // HTTP status code
  last_checked_at  DateTime? @db.Timestamptz()
  // Advanced check configuration
  check_ssl          Boolean   @default(false)
  ssl_expires_at     DateTime? @db.Timestamptz()
  ssl_issuer         String?
  ssl_days_remaining Int?
  ssl_alert_days     Int?      // null = no notification; N = alert when ≤N days remain
  check_dns          Boolean   @default(false)
  dns_resolves       Boolean?
  check_keyword      Boolean   @default(false)
  keyword            String?
  keyword_found      Boolean?
  created_at         DateTime  @default(now()) @db.Timestamptz()

  environment     Environment     @relation(fields: [environment_id], references: [id], onDelete: Cascade)
  monitor_results MonitorResult[]
  monitor_logs    MonitorLog[]
  lighthouse_audits LighthouseAudit[]

  @@map("monitors")
}

enum MonitorLogEvent {
  down
  up
  degraded
  ssl_expiry
  dns_failed
  keyword_missing
}

model MonitorLog {
  id               BigInt           @id @default(autoincrement())
  monitor_id       BigInt
  event_type       MonitorLogEvent
  status_code      Int?
  response_ms      Int?
  message          String?
  occurred_at      DateTime         @default(now()) @db.Timestamptz()
  resolved_at      DateTime?        @db.Timestamptz()
  duration_seconds Int?
  created_at       DateTime         @default(now()) @db.Timestamptz()

  monitor Monitor @relation(fields: [monitor_id], references: [id], onDelete: Cascade)

  @@index([monitor_id])
  @@index([occurred_at])
  @@map("monitor_logs")
}

model MonitorResult {
  id                 BigInt   @id @default(autoincrement())
  monitor_id         BigInt
  status_code        Int
  response_ms        Int
  is_up              Boolean
  ssl_days_remaining Int?
  dns_resolves       Boolean?
  keyword_found      Boolean?
  checked_at         DateTime @default(now()) @db.Timestamptz()

  monitor Monitor @relation(fields: [monitor_id], references: [id], onDelete: Cascade)

  @@index([monitor_id])
  @@index([checked_at])
  @@map("monitor_results")
}

enum LighthouseAuditStatus {
  queued
  running
  completed
  failed
}

enum LighthouseStrategy {
  mobile
  desktop
}

model LighthouseAudit {
  id               BigInt                @id @default(autoincrement())
  environment_id   BigInt
  monitor_id       BigInt?
  job_execution_id BigInt?
  url              String
  strategy         LighthouseStrategy    @default(mobile)
  status           LighthouseAuditStatus @default(queued)
  performance_score    Int?
  accessibility_score  Int?
  best_practices_score Int?
  seo_score            Int?
  fcp_ms          Int?
  lcp_ms          Int?
  cls             Decimal? @db.Decimal(8, 4)
  tbt_ms          Int?
  speed_index_ms  Int?
  opportunities   Json?
  summary         Json?
  raw_result      Json?
  error_message   String?
  started_at      DateTime? @db.Timestamptz()
  completed_at    DateTime? @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()

  environment Environment   @relation(fields: [environment_id], references: [id], onDelete: Cascade)
  monitor     Monitor?      @relation(fields: [monitor_id], references: [id], onDelete: SetNull)
  job_execution JobExecution? @relation(fields: [job_execution_id], references: [id], onDelete: SetNull)

  @@index([environment_id])
  @@index([monitor_id])
  @@index([job_execution_id])
  @@index([status])
  @@index([created_at])
  @@map("lighthouse_audits")
}

model PluginUpdateSchedule {
  id             BigInt    @id @default(autoincrement())
  environment_id BigInt    @unique
  enabled        Boolean   @default(true)
  frequency      String    @default("weekly") // 'daily' | 'weekly' | 'monthly'
  hour           Int       @default(2)
  minute         Int       @default(0)
  day_of_week    Int?      // 0=Sun..6=Sat (weekly only)
  day_of_month   Int?      // 1-28 (monthly only)
  last_run_at    DateTime? @db.Timestamptz()
  created_at     DateTime  @default(now()) @db.Timestamptz()
  updated_at     DateTime  @updatedAt @db.Timestamptz()

  environment Environment @relation(fields: [environment_id], references: [id], onDelete: Cascade)

  @@index([enabled])
  @@map("plugin_update_schedules")
}

model CleanupSchedule {
  id             BigInt    @id @default(autoincrement())
  environment_id BigInt    @unique
  enabled        Boolean   @default(true)
  frequency      String    @default("weekly") // 'daily' | 'weekly' | 'monthly'
  hour           Int       @default(3)
  minute         Int       @default(30)
  day_of_week    Int?      // 0=Sun..6=Sat (weekly only)
  day_of_month   Int?      // 1-28 (monthly only)
  keep_revisions Int       @default(3)
  last_run_at    DateTime? @db.Timestamptz()
  created_at     DateTime  @default(now()) @db.Timestamptz()
  updated_at     DateTime  @updatedAt @db.Timestamptz()

  environment Environment @relation(fields: [environment_id], references: [id], onDelete: Cascade)

  @@index([enabled])
  @@map("cleanup_schedules")
}

model WpDbCredentials {
  id                    BigInt   @id @default(autoincrement())
  environment_id        BigInt   @unique
  db_name_encrypted     String
  db_user_encrypted     String
  db_password_encrypted String
  db_host_encrypted     String
  created_at            DateTime @default(now()) @db.Timestamptz()
  updated_at            DateTime @updatedAt @db.Timestamptz()

  environment Environment @relation(fields: [environment_id], references: [id], onDelete: Cascade)

  @@map("wp_db_credentials")
}

// ──────────────────────────────────────────────────────────────────────────────
// SYSTEM
// ──────────────────────────────────────────────────────────────────────────────

model ExecutionScript {
  id           BigInt   @id @default(autoincrement())
  name         String   @unique // 'backup.php' | 'plugin-scan.php'
  version      String
  content_hash String
  content      String   // Full PHP script content
  created_at   DateTime @default(now()) @db.Timestamptz()

  @@map("execution_scripts")
}

model JobExecution {
  id             BigInt           @id @default(autoincrement())
  queue_name     String
  bull_job_id    String
  job_type       String?          // e.g. backup:create, backup:restore, sync:clone
  environment_id BigInt?
  server_id      BigInt?
  status         JobExecutionStatus @default(queued)
  attempt_count  Int              @default(0)
  progress       Int              @default(0) // 0-100
  last_error     String?
  payload        Json?            // Job input payload for debugging
  execution_log  Json?            // Array of ExecutionLogEntry — timestamped per-command trace
  started_at     DateTime?        @db.Timestamptz()
  completed_at   DateTime?        @db.Timestamptz()
  created_at     DateTime         @default(now()) @db.Timestamptz()

  environment    Environment?   @relation(fields: [environment_id], references: [id])
  server         Server?        @relation(fields: [server_id], references: [id])
  backups        Backup[]
  system_backups SystemBackup[]
  lighthouse_audits LighthouseAudit[]

  @@index([environment_id])
  @@index([server_id])
  @@index([bull_job_id])
  @@index([status])
  @@index([created_at])
  @@index([queue_name, status])
  @@map("job_executions")
}

enum JobExecutionStatus {
  queued
  active
  completed
  failed
  dead_letter
}

model AppSetting {
  id         BigInt   @id @default(autoincrement())
  key        String   @unique
  value      String
  updated_at DateTime @updatedAt @db.Timestamptz()

  @@map("app_settings")
}

model ResourceNote {
  id              BigInt   @id @default(autoincrement())
  resource_type   String   // project | environment | server
  resource_id     BigInt
  body            String
  pinned          Boolean  @default(false)
  created_by_id   BigInt?
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @updatedAt @db.Timestamptz()

  created_by  User?        @relation(fields: [created_by_id], references: [id], onDelete: SetNull)

  @@index([resource_type, resource_id])
  @@index([created_by_id])
  @@map("resource_notes")
}

model EnvVariableTemplate {
  id                BigInt   @id @default(autoincrement())
  name              String
  environment_type  String?
  required_keys     String[] @default([])
  secret_keys       String[] @default([])
  defaults          Json?
  created_at        DateTime @default(now()) @db.Timestamptz()
  updated_at        DateTime @updatedAt @db.Timestamptz()

  @@unique([name, environment_type])
  @@map("env_variable_templates")
}

// Forge self-backup: pg_dump of the Forge PostgreSQL DB uploaded to Google Drive
model SystemBackup {
  id               BigInt       @id @default(autoincrement())
  job_execution_id BigInt?
  status           BackupStatus @default(pending)
  file_path        String?      // gdrive:{folderId}/{filename} once uploaded
  size_bytes       BigInt?
  error_message    String?
  started_at       DateTime?    @db.Timestamptz()
  completed_at     DateTime?    @db.Timestamptz()
  created_at       DateTime     @default(now()) @db.Timestamptz()

  jobExecution JobExecution? @relation(fields: [job_execution_id], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([created_at])
  @@map("system_backups")
}

// Schedule for automated Forge self-backups (single-row config, no FK)
model SystemBackupSchedule {
  id              BigInt    @id @default(autoincrement())
  // frequency: hourly | daily | weekly | monthly
  frequency       String    @default("daily")
  hour            Int       @default(3)
  minute          Int       @default(0)
  // day_of_week: 0=Sun…6=Sat (weekly only)
  day_of_week     Int?
  // day_of_month: 1–28 (monthly only)
  day_of_month    Int?
  enabled         Boolean   @default(true)
  retention_count Int?      // keep last N backups
  retention_days  Int?      // delete backups older than N days
  last_run_at     DateTime? @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()
  updated_at      DateTime  @updatedAt @db.Timestamptz()

  @@map("system_backup_schedules")
}

// ──────────────────────────────────────────────────────────────────────────────
// CUSTOM GITHUB PLUGINS
// ──────────────────────────────────────────────────────────────────────────────

model CustomPlugin {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique // Directory name used by monorepo-fetcher
  description String?
  repo_url    String   // SSH (git@github.com:...) or HTTPS GitHub URL
  repo_path   String   @default(".") // Subdirectory within repo; "." for single-plugin repos
  type        String   @default("plugin") // plugin | theme
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @updatedAt @db.Timestamptz()

  environment_plugins EnvironmentCustomPlugin[]

  @@map("custom_plugins")
}

model EnvironmentCustomPlugin {
  id                 BigInt    @id @default(autoincrement())
  environment_id     BigInt
  custom_plugin_id   BigInt
  installed_version  String?   // Git tag at time of install, null = dev/unknown
  latest_version     String?   // Latest GitHub tag, populated by version-check
  version_checked_at DateTime? @db.Timestamptz()
  created_at         DateTime  @default(now()) @db.Timestamptz()

  environment   Environment  @relation(fields: [environment_id], references: [id], onDelete: Cascade)
  custom_plugin CustomPlugin @relation(fields: [custom_plugin_id], references: [id], onDelete: Cascade)

  @@unique([environment_id, custom_plugin_id])
  @@index([environment_id])
  @@index([custom_plugin_id])
  @@map("environment_custom_plugins")
}

// ──────────────────────────────────────────────────────────────────────────────
// BILLING
// ──────────────────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

model Invoice {
  id                       BigInt        @id @default(autoincrement())
  invoice_number           String        @unique // e.g. INV-2026-001
  project_id               BigInt
  client_id                BigInt
  hosting_package_id       BigInt?
  support_package_id       BigInt?
  hosting_package_snapshot String?       // Package name at time of generation
  support_package_snapshot String?       // Package name at time of generation
  hosting_amount           Decimal       @default(0) @db.Decimal(10, 2)
  support_amount           Decimal       @default(0) @db.Decimal(10, 2)
  total_amount             Decimal       @db.Decimal(10, 2)
  status                   InvoiceStatus @default(draft)
  period_start             DateTime      @db.Timestamptz()
  period_end               DateTime      @db.Timestamptz()
  due_date                 DateTime      @db.Timestamptz()
  paid_at                  DateTime?     @db.Timestamptz()
  notes                    String?
  created_at               DateTime      @default(now()) @db.Timestamptz()
  updated_at               DateTime      @updatedAt @db.Timestamptz()

  project         Project        @relation(fields: [project_id], references: [id])
  client          Client         @relation(fields: [client_id], references: [id])
  hosting_package HostingPackage? @relation(fields: [hosting_package_id], references: [id])
  support_package SupportPackage? @relation(fields: [support_package_id], references: [id])

  @@index([project_id])
  @@index([client_id])
  @@index([status])
  @@index([period_start, period_end])
  @@map("invoices")
}

// ──────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────────────────────────────────────

model NotificationChannel {
  id                    BigInt   @id @default(autoincrement())
  name                  String
  type                  String   @default("slack") // extensible: slack | google_chat | webhook
  slack_bot_token_enc   String?  // AES-256-GCM encrypted bot token
  slack_channel_id      String?
  google_chat_webhook_url_enc String? // AES-256-GCM encrypted incoming webhook URL
  webhook_url_enc       String?  // AES-256-GCM encrypted generic webhook URL
  webhook_secret_enc    String?  // AES-256-GCM encrypted HMAC signing secret (optional)
  events                String[] // Array of NotificationEventType strings
  active                Boolean  @default(true)
  created_at            DateTime @default(now()) @db.Timestamptz()
  updated_at            DateTime @updatedAt @db.Timestamptz()

  notification_logs NotificationLog[]

  @@map("notification_channels")
}

model NotificationLog {
  id          BigInt   @id @default(autoincrement())
  channel_id  BigInt
  event_type  String
  payload     Json
  status      String   // 'sent' | 'failed'
  error       String?
  created_at  DateTime @default(now()) @db.Timestamptz()

  channel NotificationChannel @relation(fields: [channel_id], references: [id], onDelete: Cascade)

  @@index([channel_id])
  @@index([event_type])
  @@index([status])
  @@index([created_at])
  @@map("notification_logs")
}

model UserNotification {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  type       String
  title      String
  message    String
  is_read    Boolean  @default(false)
  action_url String?
  created_at DateTime @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
  @@map("user_notifications")
}

model AuditLog {
  id            BigInt   @id @default(autoincrement())
  user_id       BigInt?
  action        String   // e.g. "backup.create", "server.delete", "auth.login"
  resource_type String?  // e.g. "backup", "server", "project"
  resource_id   BigInt?
  metadata      Json?    // Additional context (IP, user agent, diff, etc.)
  ip_address    String?
  created_at    DateTime @default(now()) @db.Timestamptz()

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([action])
  @@index([resource_type, resource_id])
  @@index([created_at])
  @@map("audit_logs")
}

// ──────────────────────────────────────────────────────────────────────────────
// SECURITY
// ──────────────────────────────────────────────────────────────────────────────

enum SecurityScanType {
  SSH_AUDIT
  SERVER_HARDENING
  MALWARE_SCAN
  WP_AUDIT
  PROJECT_MALWARE
  BACKDOOR_SEARCH
  PLUGIN_AUDIT
}

enum SecurityScanStatus {
  pending
  running
  completed
  failed
}

model SecurityScan {
  id               BigInt             @id @default(autoincrement())
  scan_type        SecurityScanType
  status           SecurityScanStatus @default(pending)
  server_id        BigInt?
  environment_id   BigInt?
  job_execution_id BigInt?
  score            Int?               // 0-100, null until scan completes
  summary          Json?              // { critical: N, high: N, medium: N, low: N, info: N }
  findings         Json?              // SecurityFinding[]
  error            String?
  started_at       DateTime?          @db.Timestamptz()
  completed_at     DateTime?          @db.Timestamptz()
  created_at       DateTime           @default(now()) @db.Timestamptz()
  updated_at       DateTime           @updatedAt @db.Timestamptz()

  server      Server?      @relation(fields: [server_id], references: [id], onDelete: Cascade)
  environment Environment? @relation(fields: [environment_id], references: [id], onDelete: Cascade)

  @@index([server_id])
  @@index([environment_id])
  @@index([scan_type])
  @@index([status])
  @@index([created_at])
  @@map("security_scans")
}

enum SecuritySeverity {
  critical
  high
  medium
  low
  info
}

model SecurityScanSchedule {
  id               BigInt            @id @default(autoincrement())
  server_id        BigInt?           @unique
  environment_id   BigInt?           @unique
  scan_types       String[]          // SecurityScanType[]
  frequency        String            // 'daily' | 'weekly' | 'monthly'
  hour             Int               @default(2)
  minute           Int               @default(0)
  day_of_week      Int?              // 0=Sun..6=Sat (weekly only)
  day_of_month     Int?              // 1-28 (monthly only)
  enabled          Boolean           @default(true)
  last_run_at      DateTime?         @db.Timestamptz()
  notify_enabled   Boolean           @default(false)
  notify_threshold SecuritySeverity  @default(critical)
  created_at       DateTime          @default(now()) @db.Timestamptz()
  updated_at       DateTime          @updatedAt @db.Timestamptz()

  server      Server?      @relation(fields: [server_id], references: [id], onDelete: Cascade)
  environment Environment? @relation(fields: [environment_id], references: [id], onDelete: Cascade)

  @@index([enabled])
  @@map("security_scan_schedules")
}

model ServerSecurityAlertSetting {
  id                         BigInt    @id @default(autoincrement())
  server_id                  BigInt    @unique
  enabled                    Boolean   @default(false)
  ssh_login_alerts_enabled   Boolean   @default(true)
  file_change_alerts_enabled Boolean   @default(true)
  interval_minutes           Int       @default(5)
  file_watch_paths           String[]  @default([])
  last_checked_at            DateTime? @db.Timestamptz()
  last_auth_cursor           String?
  file_snapshot              Json?
  created_at                 DateTime  @default(now()) @db.Timestamptz()
  updated_at                 DateTime  @updatedAt @db.Timestamptz()

  server Server @relation(fields: [server_id], references: [id], onDelete: Cascade)

  @@index([enabled])
  @@map("server_security_alert_settings")
}

// Acknowledged (reviewed/accepted-risk) security findings.
// Keyed by scope_key + category + title — persists across rescans.
model SecurityFindingAck {
  id               BigInt   @id @default(autoincrement())
  scope_key        String   @db.VarChar(64)  // "server:123" or "environment:456"
  category         String   @db.VarChar(64)
  title            String   @db.VarChar(256)
  server_id        BigInt?
  environment_id   BigInt?
  acknowledged_by  BigInt
  note             String?  @db.Text
  created_at       DateTime @default(now()) @db.Timestamptz()

  user        User         @relation(fields: [acknowledged_by], references: [id], onDelete: Cascade)
  server      Server?      @relation(fields: [server_id], references: [id], onDelete: Cascade)
  environment Environment? @relation(fields: [environment_id], references: [id], onDelete: Cascade)

  @@unique([scope_key, category, title])
  @@index([scope_key])
  @@map("security_finding_acks")
}

// ──────────────────────────────────────────────────────────────────────────────
// MAINTENANCE WINDOWS
// ──────────────────────────────────────────────────────────────────────────────

/// Suppresses monitor alerts and security alert polling during planned maintenance.
model MaintenanceWindow {
  id             BigInt    @id @default(autoincrement())
  resource_type  String    // "server" | "environment" | "project"
  resource_id    BigInt    // the ID of the server or environment or project
  server_id      BigInt?   // set when resource_type = "server"
  environment_id BigInt?   // set when resource_type = "environment"
  reason         String?   @db.Text
  starts_at      DateTime  @db.Timestamptz()
  ends_at        DateTime  @db.Timestamptz()
  created_by_id  BigInt?
  created_at     DateTime  @default(now()) @db.Timestamptz()

  created_by  User?        @relation(fields: [created_by_id], references: [id], onDelete: SetNull)
  server      Server?      @relation(fields: [server_id], references: [id], onDelete: Cascade)
  environment Environment? @relation(fields: [environment_id], references: [id], onDelete: Cascade)

  @@index([resource_type, resource_id])
  @@index([starts_at, ends_at])
  @@map("maintenance_windows")
}
