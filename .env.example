# Bedrock Forge Environment Configuration
# Copy this file to .env and update with your values

# Application
APP_NAME="Bedrock Forge"
DEBUG=false
API_V1_PREFIX="/api/v1"

# Database
# SQLite (development)
DATABASE_URL="sqlite+aiosqlite:///./forge.db"
# PostgreSQL (production)
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/forge"
DATABASE_ECHO=false

# Security - REQUIRED: Generate a secret key
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="your-secret-key-here-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for credential vault
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=""

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD="minute"

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Redis (for rate limiting and caching)
REDIS_URL="redis://localhost:6379/0"

# ===========================================
# SEEDING CONFIGURATION
# ===========================================

# Demo mode (uses fake/example data for seeding)
# Set to false to use real credentials from environment
SEED_DEMO_MODE=true

# Default admin user (only used if SEED_DEMO_MODE=false)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_FULL_NAME=""

# Demo server configuration (only used if SEED_DEMO_MODE=false)
SEED_SERVER_NAME=""
SEED_SERVER_HOSTNAME=""
SEED_SERVER_IP=""
SEED_SERVER_SSH_USER=""
SEED_SERVER_SSH_PORT=22
SEED_SERVER_SSH_KEY_PATH=""

# CyberPanel credentials (if using CyberPanel)
SEED_CYBERPANEL_USER=""
SEED_CYBERPANEL_PASSWORD=""

# ===========================================
# EXTERNAL INTEGRATIONS
# ===========================================

# GitHub OAuth (for GitHub integration)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_PERSONAL_TOKEN=""

# Google Drive (for backup integration)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# Cloudflare (for DNS/SSL management)
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# ===========================================
# NOTIFICATION CHANNELS
# ===========================================

# Email/SMTP
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME="Bedrock Forge"
SMTP_USE_TLS=true

# Slack (create webhook at https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=""

# Discord (create webhook in server settings)
DISCORD_WEBHOOK_URL=""

# Telegram (create bot with @BotFather)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ===========================================
# FIRST SUPERUSER (for initial setup)
# Used only on first startup if no users exist
# ===========================================
FIRST_SUPERUSER_EMAIL=""
FIRST_SUPERUSER_PASSWORD=""
