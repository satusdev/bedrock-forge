# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://forge:forge_password@postgres:5432/bedrock_forge

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_me_different_from_jwt_secret

# ─── Encryption ─────────────────────────────────────────────
# Must be exactly 64 hex chars (32 bytes for AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change_me_exactly_64_hex_characters_for_aes256_encryption

# ─── Application ─────────────────────────────────────────────
NODE_ENV=production
API_PORT=3000
BACKUP_STORAGE_PATH=/var/forge/backups
# CORS origin — set to your nginx/CDN origin in production
CORS_ORIGIN=http://localhost:8080

# ─── Worker ──────────────────────────────────────────────────
# PHP scripts path — auto-detected from __dirname if not set
# SCRIPTS_PATH=/app/apps/worker/scripts

# ─── Postgres (for docker-compose only) ──────────────────────
POSTGRES_DB=bedrock_forge
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge_password
