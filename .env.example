# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://forge:forge_password@postgres:5432/bedrock_forge

# ─── Redis ──────────────────────────────────────────────────
# REDIS_PASSWORD is required in production. Generate with: openssl rand -hex 16
REDIS_PASSWORD=change_me_generate_with_openssl_rand_hex_16
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ─── JWT ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_me_different_from_jwt_secret

# ─── Encryption ─────────────────────────────────────────────
# Must be exactly 64 hex chars (32 bytes for AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change_me_exactly_64_hex_characters_for_aes256_encryption

# ─── Application ─────────────────────────────────────────────
NODE_ENV=production
API_PORT=3000
BACKUP_STORAGE_PATH=/var/forge/backups
# CORS origin — set to your nginx/CDN origin in production
CORS_ORIGIN=http://localhost:8080

# ─── Worker ──────────────────────────────────────────────────
# PHP scripts path — auto-detected from __dirname if not set
# SCRIPTS_PATH=/app/apps/worker/scripts

# ─── Postgres (for docker-compose only) ──────────────────────
POSTGRES_DB=bedrock_forge
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge_password

# ─── Google Drive / rclone backup target ─────────────────────
# Obtain from Google Cloud Console → APIs → Credentials → OAuth 2.0 Client ID
# Required only when using GDrive as a backup storage backend.
# GDRIVE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GDRIVE_CLIENT_SECRET=your_client_secret
# GDRIVE_TOKEN={"access_token":"...","refresh_token":"...","expiry":"..."}
# Optional: root folder ID to confine uploads; defaults to GDrive root.
# GDRIVE_FOLDER_ID=

# ─── Dev / Seed credentials (web frontend, development only) ─
# When set, a "Dev Login" button appears on the login page.
# Should match the user created by `pnpm db:seed`.
# VITE_DEV_EMAIL=admin@bedrockforge.local
# VITE_DEV_PASSWORD=admin123
