# Bedrock Forge - Production Docker Environment
# Copy to .env for production deployment:
# cp .env.production.example .env

COMPOSE_PROJECT_NAME=forge

POSTGRES_USER=forge
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=forge

SECRET_KEY=<CHANGE_ME>
ENCRYPTION_KEY=<OPTIONAL_BUT_RECOMMENDED>
DEBUG=false

CORS_ORIGINS=["https://your-domain.com"]

VITE_API_BASE_URL=https://your-domain.com/api/v1
VITE_WS_URL=wss://your-domain.com/api/v1/ws

SEED_DEMO_MODE=false
SEED_ADMIN_EMAIL=<CHANGE_ME>
SEED_ADMIN_PASSWORD=<CHANGE_ME>
SEED_ADMIN_FULL_NAME=Administrator

# Optional integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_DRIVE_CREDENTIALS_FILE=
GOOGLE_DRIVE_TOKEN_FILE=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
CLOUDFLARE_API_TOKEN=
# Optional absolute path to rclone.conf file (must be a file path, not a directory)
RCLONE_CONFIG=
